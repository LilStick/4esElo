# PostgreSQL (matches docker-compose.yml)
DATABASE_URL=postgres://4eselo:4eselo@localhost:5432/4eselo

# Faceit Data API — get a key at https://developers.faceit.com
FACEIT_API_KEY=

# Discord bot (phase 2)
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=

# API
API_PORT=3001

# Web (Vite) — URL de l'API consommée par le front
VITE_API_URL=http://localhost:3001

# Notif Discord bot
DISCORD_WEBHOOK_URL=
DISCORD_BOT_TOKEN=

# Auth Discord (B17.1) — tout-ou-rien : soit les 5 obligatoires sont remplies, soit
# aucune (auth désactivée, site consultable). App OAuth : https://discord.com/developers
# En dev, un redirect URI localhost marche (à déclarer dans l'app Discord).
DISCORD_OAUTH_CLIENT_ID=
DISCORD_OAUTH_CLIENT_SECRET=
DISCORD_OAUTH_REDIRECT_URI=http://localhost:3001/auth/callback
DISCORD_ASSO_GUILD_ID=
SESSION_SECRET=
# Optionnels
DISCORD_ASSO_INVITE_URL=
ADMIN_DISCORD_IDS=