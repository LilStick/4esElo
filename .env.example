# ── PostgreSQL (matches docker-compose.yml) ──
DATABASE_URL=postgres://4eselo:4eselo@localhost:5432/4eselo

# ── Faceit Data API (clé server-side) — https://developers.faceit.com ──
# Obligatoire pour le worker (refuse de démarrer sans) + le register côté API.
FACEIT_API_KEY=

# ── Steam Web API — https://steamcommunity.com/dev/apikey ──
# Présence « en jeu » + playtime. Optionnel (features dégradées si absent).
STEAM_API_KEY=

# ── API ──
API_PORT=3001
# CORS : origines autorisées (séparées par des virgules).
# ⚠️ EN PROD = l'URL du front (ex. https://elo.mondomaine.fr) sinon le front est bloqué.
WEB_ORIGINS=http://localhost:5173

# ── Web (Vite) — URL de l'API consommée par le front ──
# En prod = l'URL publique de l'API.
VITE_API_URL=http://localhost:3001

# ── Auth Discord / register (B17) — TOUT-OU-RIEN ──
# Soit les 5 remplies (auth active), soit aucune (auth off, site consultable).
# App OAuth : https://discord.com/developers — déclarer le redirect URI (localhost dev / domaine prod).
DISCORD_OAUTH_CLIENT_ID=
DISCORD_OAUTH_CLIENT_SECRET=
DISCORD_OAUTH_REDIRECT_URI=http://localhost:3001/auth/callback
DISCORD_ASSO_GUILD_ID=
# 32 caractères min — générer avec : openssl rand -hex 32
SESSION_SECRET=
# Optionnels
DISCORD_ASSO_INVITE_URL=
ADMIN_DISCORD_IDS=

# ── Boîte à idées (B17.7 / vote B17.12) ──
# Le bot dev poste l'idée + amorce ✅/❌. Fallback webhook si pas de bot.
DISCORD_BOT_TOKEN=
DISCORD_IDEAS_CHANNEL_ID=
DISCORD_IDEAS_WEBHOOK_URL=

# ── Outillage / skills (dev, pas l'app) ──
# Salon #features-talk où les skills postent les idées à voter (propose-idea / tally-votes).
DISCORD_FEATURES_CHANNEL_ID=

# ── Worker (optionnel) ──
# Intervalle du sync en ms (défaut 600000 = 10 min).
WORKER_INTERVAL_MS=600000
